// ===== EVALUATION =====
function initStars(prefix,fields){
  fields.forEach(function(f){
    var el=document.getElementById('stars-'+prefix+'-'+f);
    if(!el)return;
    el.innerHTML='';
    for(var i=1;i<=5;i++){
      (function(score,field,pref){
        var s=document.createElement('button');
        s.className='star';s.textContent='★';
        s.onclick=function(){setStarScore(pref,field,score);};
        el.appendChild(s);
      })(i,f,prefix);
    }
  });
}

function setStarScore(prefix,field,score){
  evalData[prefix][field]=score;
  var el=document.getElementById('stars-'+prefix+'-'+field);
  if(!el)return;
  var stars=el.querySelectorAll('.star');
  stars.forEach(function(s,i){s.className='star'+(i<score?' on':'');});
  document.getElementById('score-'+prefix+'-'+field).textContent=score;
  updateAvg(prefix);
}

function updateAvg(prefix){
  var vals=Object.values(evalData[prefix]);
  var avg=vals.length?vals.reduce(function(a,b){return a+b;},0)/vals.length:0;
  var el=document.getElementById(prefix+'-avg');
  if(el)el.textContent=avg.toFixed(1);
}

function initEval(r){
  if(r.eval){evalData=JSON.parse(JSON.stringify(r.eval));delete evalData.classif;delete evalData.finalScore;}
  initStars('hr',['exp','edu','comm','stab','cult']);
  initStars('mgr',['tech','ops','prob','lead']);
  // restore scores
  ['exp','edu','comm','stab','cult'].forEach(function(f){if(evalData.hr&&evalData.hr[f])setStarScore('hr',f,evalData.hr[f]);});
  ['tech','ops','prob','lead'].forEach(function(f){if(evalData.mgr&&evalData.mgr[f])setStarScore('mgr',f,evalData.mgr[f]);});
  showEvalTab('hr');
}

function showEvalTab(tab){
  document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('on');});
  document.querySelectorAll('[onclick*="showEvalTab"]').forEach(function(t){if(t.getAttribute('onclick').includes("'"+tab+"'"))t.classList.add('on');});
  document.getElementById('eval-hr').style.display=tab==='hr'?'block':'none';
  document.getElementById('eval-mgr').style.display=tab==='mgr'?'block':'none';
  document.getElementById('eval-result').style.display=tab==='result'?'block':'none';
  if(tab==='result')calcFinalScore();
}

function calcFinalScore(){
  var hrVals=Object.values(evalData.hr||{});
  var mgrVals=Object.values(evalData.mgr||{});
  var hrAvg=hrVals.length?hrVals.reduce(function(a,b){return a+b;},0)/hrVals.length:0;
  var mgrAvg=mgrVals.length?mgrVals.reduce(function(a,b){return a+b;},0)/mgrVals.length:0;
  var final=(hrAvg*0.4)+(mgrAvg*0.6);
  document.getElementById('final-score-display').textContent=final.toFixed(1);
  // auto classify
  if(final>=4.5)setClassif('ممتاز','cl-ex','active-ex');
  else if(final>=3.5)setClassif('قوي','cl-st','active-st');
  else if(final>=2.5)setClassif('جيد','cl-gd','active-gd');
  else setClassif('غير مناسب','cl-no','active-no');
  return final;
}

function setClassif(label,btnId,activeClass){
  curClassif=label;
  ['cl-ex','cl-st','cl-gd','cl-no'].forEach(function(id){var el=document.getElementById(id);if(el)el.className='classif-item';});
  var el=document.getElementById(btnId);if(el)el.className='classif-item '+activeClass;
}

function saveEval(){
  var final=calcFinalScore();
  loadDB();
  for(var i=0;i<DB.reqs.length;i++){
    if(DB.reqs[i].id===curDetId){
      DB.reqs[i].eval={hr:evalData.hr,mgr:evalData.mgr,classif:curClassif,finalScore:final};
      DB.reqs[i].log=DB.reqs[i].log||[];
      DB.reqs[i].log.push({t:'تم حفظ تقييم المرشح: '+curClassif+' ('+final.toFixed(1)+')',s:(curUser?curUser.name:'')+' — '+today(),ts:Date.now()});
