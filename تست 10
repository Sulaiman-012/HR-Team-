  if(search)logs=logs.filter(function(l){return(l.user+l.action+l.detail+l.reqId).includes(search);});
  var tbody=document.getElementById('audit-tbody');
  if(!logs.length){tbody.innerHTML='<tr><td colspan="5"><div class="empty">لا توجد سجلات بعد</div></td></tr>';return;}
  tbody.innerHTML=logs.map(function(l){var ts=new Date(l.ts);var ds=ts.toLocaleDateString('ar-SA')+' '+ts.toLocaleTimeString('ar-SA',{hour:'2-digit',minute:'2-digit'});return'<tr><td style="font-size:10px;color:#6B6960;white-space:nowrap">'+ds+'</td><td style="font-size:12px;font-weight:500">'+l.user+'</td><td style="font-size:12px">'+l.action+'</td><td style="font-family:monospace;font-size:10px;color:#6B6960">'+(l.reqId||'—')+'</td><td style="font-size:11px;color:#6B6960">'+(l.detail||'—')+'</td></tr>';}).join('');
}

// ===== EXECUTIVE DASHBOARD =====
function renderExec(){
  loadDB();
  document.getElementById('exec-date').textContent=today();
  var R=DB.reqs||[];
  var C=DB.cands||[];
  var wf=getWFData();

  // KPIs
  var open=R.filter(function(r){return r.status!=='onboard';}).length;
  var critical=R.filter(function(r){return r.critical==='yes'&&r.status!=='onboard';}).length;
  var saud=R.filter(function(r){return r.saudization==='yes';}).length;
  var saudDone=R.filter(function(r){return r.saudization==='yes'&&r.status==='onboard';}).length;
  var saudPct=saud>0?Math.round(saudDone/saud*100):0;
  var tA=wf.reduce(function(a,b){return a+b.approved;},0);
  var tC=wf.reduce(function(a,b){return a+b.current;},0);
  var occPct=tA>0?Math.round(tC/tA*100):0;
  var ttf=calcTTF(R);
  var offers=R.filter(function(r){return r.status==='offer'||r.status==='offer_accept'||r.status==='onboard';}).length;
  var hired=R.filter(function(r){return r.status==='onboard';}).length;
  var oar=offers>0?Math.round(hired/offers*100):0;

  var kpis=[
    {n:open,l:'إجمالي الشواغر',c:'#174E88',sub:critical+' حرجة'},
    {n:occPct+'%',l:'نسبة اكتمال القوى العاملة',c:occPct>=90?'#136438':occPct>=70?'#B08D3C':'#8A1A1A',sub:tC+' من '+tA},
    {n:saudPct+'%',l:'نسبة إنجاز التوطين',c:'#136438',sub:saudDone+' من '+saud+' مستهدفة'},
    {n:ttf>0?ttf+' يوم':'—',l:'متوسط مدة التوظيف',c:'#4A2080',sub:'Time to Fill'},
    {n:oar+'%',l:'Offer Acceptance Rate',c:'#B08D3C',sub:hired+' تعيين من '+offers+' عرض'},
    {n:critical,l:'وظائف حرجة مفتوحة',c:'#8A1A1A',sub:'تحتاج أولوية'},
    {n:C.length,l:'بنك المواهب',c:'#3E1A7A',sub:'مرشح متاح'},
    {n:R.length,l:'إجمالي الطلبات',c:'#1A1916',sub:'منذ بدء النظام'},
  ];
  document.getElementById('exec-kpis').innerHTML=kpis.map(function(k){
    return'<div style="background:#fff;border:1px solid #E2E0D6;border-radius:10px;padding:14px;position:relative;overflow:hidden">'+
      '<div style="position:absolute;top:0;right:0;width:3px;height:100%;background:'+k.c+'"></div>'+
      '<div style="font-size:22px;font-weight:700;color:'+k.c+';margin-bottom:2px">'+k.n+'</div>'+
      '<div style="font-size:10px;color:#6B6960;margin-bottom:3px">'+k.l+'</div>'+
      '<div style="font-size:10px;color:'+k.c+';font-weight:500">'+k.sub+'</div></div>';
  }).join('');

  // الشركات الأعلى احتياجاً
  var coMap={};
  var COS_LIST=['دام القابضة','رصف','العربات الفاخرة','عناوان الضيافة','شاطبة للمقاولات','مرخ للوجبات','معاقد للمقاولات','المنازل'];
  var COS_ICONS={'دام القابضة':'👑','رصف':'🏗️','العربات الفاخرة':'🚗','عناوان الضيافة':'🏨','شاطبة للمقاولات':'🏚️','مرخ للوجبات':'🍽️','معاقد للمقاولات':'🔧','المنازل':'🏠'};
  R.forEach(function(r){if(r.status!=='onboard')coMap[r.coName]=(coMap[r.coName]||0)+1;});
  var coArr=Object.keys(coMap).sort(function(a,b){return coMap[b]-coMap[a];}).slice(0,6);
  var maxCo=coArr.length?coMap[coArr[0]]:1;
  document.getElementById('exec-co-chart').innerHTML=coArr.length?coArr.map(function(co){
    var n=coMap[co];var pct=Math.round(n/maxCo*100);
    return'<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">'+
      '<div style="min-width:90px;font-size:11px;font-weight:500">'+(COS_ICONS[co]||'🏢')+' '+co+'</div>'+
      '<div style="flex:1;height:22px;background:#F0EEE8;border-radius:4px;overflow:hidden">'+
        '<div style="height:100%;width:'+pct+'%;background:#174E88;border-radius:4px;display:flex;align-items:center;padding:0 6px">'+
          '<span style="color:#fff;font-size:10px;font-weight:600">'+n+'</span></div></div></div>';
  }).join(''):'<div class="empty">لا توجد طلبات بعد</div>';

  // مصادر الاستقطاب
  var srcMap={};
  C.forEach(function(c){if(c.source)srcMap[c.source]=(srcMap[c.source]||0)+1;});
  var srcArr=Object.keys(srcMap).sort(function(a,b){return srcMap[b]-srcMap[a];});
  var maxSrc=srcArr.length?srcMap[srcArr[0]]:1;
  var srcColors=['#174E88','#B08D3C','#136438','#4A2080','#8A4E0C'];
  document.getElementById('exec-sources-chart').innerHTML=srcArr.length?srcArr.map(function(s,i){
    var n=srcMap[s];var pct=Math.round(n/maxSrc*100);var color=srcColors[i%srcColors.length];
    return'<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">'+
      '<div style="min-width:80px;font-size:11px;font-weight:500">'+s+'</div>'+
      '<div style="flex:1;height:22px;background:#F0EEE8;border-radius:4px;overflow:hidden">'+
        '<div style="height:100%;width:'+pct+'%;background:'+color+';border-radius:4px;display:flex;align-items:center;padding:0 6px">'+
          '<span style="color:#fff;font-size:10px;font-weight:600">'+n+'</span></div></div>'+
      '<div style="font-size:10px;color:#6B6960">'+Math.round(n/(C.length||1)*100)+'%</div></div>';
  }).join(''):'<div class="empty">لا توجد بيانات — أضف مرشحين في بنك المواهب</div>';

  // Pipeline توزيع
  var pipMap={};
  R.forEach(function(r){pipMap[r.status]=(pipMap[r.status]||0)+1;});
  var pipColors={'need':'#8A4E0C','fin_approval':'#8A4E0C','hr_approval':'#174E88','sourcing':'#4A2080','screening':'#4A2080','int1':'#4A2080','int2':'#4A2080','offer':'#B08D3C','offer_accept':'#B08D3C','handover':'#136438','onboard':'#136438'};
  var pipLabels={'need':'تحديد الاحتياج','fin_approval':'اعتماد المالية','hr_approval':'اعتماد HR','sourcing':'البحث','screening':'فرز السير','int1':'مقابلة أولى','int2':'مقابلة نهائية','offer':'عرض وظيفي','offer_accept':'قبول العرض','handover':'التسليم','onboard':'المباشرة'};
  var pipKeys=Object.keys(pipMap).sort(function(a,b){return pipMap[b]-pipMap[a];});
  var maxPip=pipKeys.length?pipMap[pipKeys[0]]:1;
  document.getElementById('exec-pipeline-chart').innerHTML=pipKeys.length?pipKeys.map(function(k){
    var n=pipMap[k];var pct=Math.round(n/maxPip*100);var color=pipColors[k]||'#6B6960';
    return'<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">'+
      '<div style="min-width:110px;font-size:10px;font-weight:500">'+(pipLabels[k]||k)+'</div>'+
      '<div style="flex:1;height:20px;background:#F0EEE8;border-radius:4px;overflow:hidden">'+
        '<div style="height:100%;width:'+pct+'%;background:'+color+';border-radius:4px;display:flex;align-items:center;padding:0 6px">'+
          '<span style="color:#fff;font-size:10px;font-weight:600">'+n+'</span></div></div></div>';
  }).join(''):'<div class="empty">لا توجد طلبات بعد</div>';

  // التوطين لكل شركة
  var saudCoMap={};
  R.filter(function(r){return r.saudization==='yes';}).forEach(function(r){
    if(!saudCoMap[r.coName])saudCoMap[r.coName]={total:0,done:0,icon:r.coIcon||'🏢'};
    saudCoMap[r.coName].total++;
    if(r.status==='onboard')saudCoMap[r.coName].done++;
  });
  var saudKeys=Object.keys(saudCoMap);
  document.getElementById('exec-saud-chart').innerHTML=saudKeys.length?saudKeys.map(function(co){
    var d=saudCoMap[co];var pct=d.total>0?Math.round(d.done/d.total*100):0;
    var color=pct>=80?'#136438':pct>=50?'#B08D3C':'#8A1A1A';
    return'<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">'+
      '<div style="min-width:90px;font-size:11px;font-weight:500">'+d.icon+' '+co+'</div>'+
      '<div style="flex:1;height:22px;background:#F0EEE8;border-radius:4px;overflow:hidden">'+
        '<div style="height:100%;width:'+pct+'%;background:'+color+';border-radius:4px;display:flex;align-items:center;padding:0 6px">'+
          '<span style="color:#fff;font-size:10px;font-weight:600">'+pct+'%</span></div></div>'+
      '<div style="font-size:10px;color:#6B6960">'+d.done+'/'+d.total+'</div></div>';
  }).join(''):'<div class="empty">لا توجد وظائف مستهدفة بالتوطين بعد</div>';

  // جدول ملخص الشركات
  var tbody='';
  wf.forEach(function(w){
    var v=w.approved-w.current;
    var occ=w.approved>0?Math.round(w.current/w.approved*100):0;
    var occColor=occ>=90?'#136438':occ>=70?'#B08D3C':'#8A1A1A';
    var openR=R.filter(function(r){return r.coName===w.co&&r.status!=='onboard';}).length;
    var critR=R.filter(function(r){return r.coName===w.co&&r.critical==='yes'&&r.status!=='onboard';}).length;
    var saudR=R.filter(function(r){return r.coName===w.co&&r.saudization==='yes';}).length;
    var saudDoneR=R.filter(function(r){return r.coName===w.co&&r.saudization==='yes'&&r.status==='onboard';}).length;
    tbody+='<tr>'+
      '<td style="font-weight:500">'+w.i+' '+w.co+'</td>'+
      '<td style="text-align:center">'+w.approved+'</td>'+
      '<td style="text-align:center">'+w.current+'</td>'+
      '<td style="text-align:center;color:#8A4E0C;font-weight:500">'+v+'</td>'+
      '<td><div style="display:flex;align-items:center;gap:6px"><div style="width:60px;height:6px;background:#F0EEE8;border-radius:3px;overflow:hidden"><div style="height:100%;width:'+occ+'%;background:'+occColor+'"></div></div><span style="font-size:11px;font-weight:600;color:'+occColor+'">'+occ+'%</span></div></td>'+
      '<td style="text-align:center">'+(openR>0?'<span class="badge b-amber">'+openR+'</span>':'—')+'</td>'+
      '<td style="text-align:center">'+(critR>0?'<span class="badge b-critical">⚡'+critR+'</span>':'—')+'</td>'+
      '<td style="text-align:center">'+(saudR>0?saudDoneR+'/'+saudR+' <span style="color:#136438;font-size:10px">('+Math.round(saudDoneR/saudR*100)+'%)</span>':'—')+'</td></tr>';
  });
  document.getElementById('exec-summary-tbody').innerHTML=tbody;
}

// ===== INIT =====
initSupa();
loadDB();
// Load fresh data from Supabase
if(supa){loadFromSupabase();}
document.getElementById('li-email').addEventListener('keydown',function(e){if(e.keyCode===13)document.getElementById('li-pass').focus();});
document.getElementById('li-pass').addEventListener('keydown',function(e){if(e.keyCode===13)doLogin();});
setToggle('critical','no');
setToggle('saudization','no');
// Auto-refresh every 30 seconds when on dashboard
setInterval(function(){
  var cur='';
  document.querySelectorAll('.pg').forEach(function(p){if(p.style.display==='block')cur=p.id.replace('pg-','');});
  if(supa&&['dash','fin','critical','saudization','exec'].indexOf(cur)>=0){loadFromSupabase();}
},30000);
</script>
