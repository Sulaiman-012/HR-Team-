<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Dam Jobs</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,Arial,sans-serif;background:#F4F3EF;color:#1A1916;min-height:100vh;font-size:14px}
.pg{display:none}.pg.on{display:block}

/* NAV */
nav{background:#1A1916;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;position:sticky;top:0;z-index:99}
.logo{font-size:15px;font-weight:700;color:#B08D3C;letter-spacing:.5px}
.nav-end{display:flex;align-items:center;gap:10px}
.role-pill{background:rgba(255,255,255,.1);color:rgba(255,255,255,.65);font-size:10px;padding:3px 10px;border-radius:20px}
.back-btn{background:rgba(255,255,255,.1);color:#fff;border:none;padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer;font-family:inherit;display:none}
.av-btn{width:30px;height:30px;border-radius:50%;background:#B08D3C;color:#fff;font-size:11px;font-weight:700;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center}

/* LAYOUT */
.wrap{max-width:700px;margin:0 auto;padding:22px 16px}
.wrap-lg{max-width:1100px;margin:0 auto;padding:22px 16px}
.card{background:#fff;border:1px solid #E2E0D6;border-radius:10px;padding:18px;margin-bottom:12px}
.sec{font-size:11px;font-weight:600;color:#6B6960;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #E2E0D6;display:flex;align-items:center;gap:5px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.f label{font-size:11px;font-weight:500;color:#6B6960;display:block;margin-bottom:3px}
.f input,.f select,.f textarea{font-size:13px;padding:8px 10px;border:1px solid #E2E0D6;border-radius:6px;background:#fff;color:#1A1916;font-family:inherit;width:100%;outline:none}
.f textarea{min-height:56px;resize:vertical}
.f input:focus,.f select:focus,.f textarea:focus{border-color:#B08D3C}

/* BUTTONS */
.btn{display:flex;align-items:center;justify-content:center;gap:5px;padding:9px 18px;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;border:none;font-family:inherit;width:100%;margin-top:6px;transition:opacity .15s}
.btn:hover{opacity:.88}
.btn-gold{background:#B08D3C;color:#fff}
.btn-green{background:#136438;color:#fff}
.btn-red{background:#8A1A1A;color:#fff}
.btn-gray{background:#E2E0D6;color:#1A1916}
.btn-wa{background:#25D366;color:#fff}
.btn-blue{background:#174E88;color:#fff}
.btn-sm{padding:5px 12px;font-size:11px;width:auto;margin-top:0}

/* BADGES */
.badge{display:inline-flex;align-items:center;font-size:10px;padding:2px 8px;border-radius:20px;font-weight:500;white-space:nowrap}
.b-blue{background:#EAF1FB;color:#174E88;border:1px solid #B5D0EF}
.b-amber{background:#FDF2E0;color:#8A4E0C;border:1px solid #EDCA7A}
.b-green{background:#E5F4EC;color:#136438;border:1px solid #A5D9BC}
.b-red{background:#FBE8E8;color:#8A1A1A;border:1px solid #E8AAAA}
.b-purple{background:#F0EAF8;color:#4A2080;border:1px solid #C8A8E8}
.b-gold{background:#F8F2E3;color:#B08D3C;border:1px solid #DFC98A}
.b-gray{background:#F0EEE8;color:#666;border:1px solid #E2E0D6}
.b-critical{background:#FBE8E8;color:#8A1A1A;border:1px solid #E8AAAA;font-weight:700}
.b-saudization{background:#E5F4EC;color:#136438;border:1px solid #A5D9BC;font-weight:700}

/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:18px}
.stat{background:#fff;border:1px solid #E2E0D6;border-radius:10px;padding:14px}
.stat-n{font-size:24px;font-weight:700;line-height:1;margin-bottom:3px}
.stat-l{font-size:10px;color:#6B6960}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-bottom:14px}
.kpi{background:#fff;border:1px solid #E2E0D6;border-radius:10px;padding:14px;position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;top:0;right:0;width:3px;height:100%;background:#B08D3C}
.kpi-n{font-size:20px;font-weight:700;margin-bottom:2px}
.kpi-l{font-size:10px;color:#6B6960;margin-bottom:4px}
.kpi-sub{font-size:10px;color:#B08D3C;font-weight:500}

/* TABLE */
.tbl{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:right;padding:8px 10px;border-bottom:1px solid #E2E0D6;font-size:11px;font-weight:600;color:#6B6960;background:#FAFAF6;white-space:nowrap}
td{padding:8px 10px;border-bottom:1px solid #E2E0D6;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#FAFAF7}

/* PIPELINE — 11 مرحلة */
.pipeline{display:flex;overflow-x:auto;padding-bottom:6px;margin-bottom:14px;gap:0}
.pip-item{flex:1;min-width:64px;display:flex;flex-direction:column;align-items:center;gap:3px;position:relative;cursor:pointer}
.pip-item:not(:last-child)::after{content:'';position:absolute;top:11px;left:0;width:50%;height:1.5px;background:#E2E0D6}
.pip-item:not(:first-child)::before{content:'';position:absolute;top:11px;right:0;width:50%;height:1.5px;background:#E2E0D6}
.pip-item.done::after,.pip-item.done::before,.pip-item.cur::before{background:#B08D3C}
.pip-dot{width:22px;height:22px;border-radius:50%;border:1.5px solid #E2E0D6;background:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;z-index:1;position:relative;color:#6B6960;transition:all .2s}
.pip-item.done .pip-dot{background:#B08D3C;border-color:#B08D3C;color:#fff}
.pip-item.cur .pip-dot{background:#174E88;border-color:#174E88;color:#fff;box-shadow:0 0 0 3px #EAF1FB}
.pip-item.cur .pip-lbl{color:#174E88;font-weight:600}
.pip-item.done .pip-lbl{color:#136438}
.pip-lbl{font-size:8px;color:#6B6960;text-align:center;line-height:1.3;max-width:62px}

/* EVALUATION */
.eval-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #E2E0D6}
.eval-item:last-child{border-bottom:none}
.eval-label{font-size:12px;color:#1A1916;flex:1}
.eval-stars{display:flex;gap:3px}
.star{width:24px;height:24px;border-radius:4px;border:1px solid #E2E0D6;background:#fff;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.star.on{background:#B08D3C;border-color:#B08D3C;color:#fff}
.eval-score{font-size:12px;font-weight:600;color:#B08D3C;min-width:24px;text-align:center}

/* CLASSIFICATION */
.classif{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.classif-item{padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;border:1.5px solid #E2E0D6;background:#fff;cursor:pointer;font-family:inherit}
.classif-item.active-ex{border-color:#136438;background:#E5F4EC;color:#136438}
.classif-item.active-st{border-color:#174E88;background:#EAF1FB;color:#174E88}
.classif-item.active-gd{border-color:#B08D3C;background:#F8F2E3;color:#B08D3C}
.classif-item.active-no{border-color:#8A1A1A;background:#FBE8E8;color:#8A1A1A}

/* DETAIL ROW */
.dr{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #E2E0D6}
.dr:last-child{border-bottom:none}
.dl{color:#6B6960;font-size:11px;min-width:130px;flex-shrink:0}
.dv{color:#1A1916;flex:1;text-align:left;font-size:12px}

/* WA BOX */
.wa-box{background:#E5F4EC;border:1px solid #A5D9BC;border-radius:8px;padding:11px;margin-bottom:10px}
.wa-msg{font-size:11px;color:#136438;line-height:1.8;white-space:pre-wrap;word-break:break-all;font-family:monospace}

/* MISC */
.err{background:#FBE8E8;border:1px solid #E8AAAA;border-radius:6px;padding:8px;font-size:12px;color:#8A1A1A;margin-bottom:8px;display:none}
.suc{text-align:center;padding:40px 20px}
.empty{text-align:center;padding:28px;color:#6B6960;font-size:12px}
.notif{position:fixed;bottom:18px;left:50%;transform:translateX(-50%);background:#1A1916;color:#fff;padding:8px 18px;border-radius:8px;font-size:12px;z-index:999;display:none;white-space:nowrap}
.co-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.co-btn{background:#fff;border:1.5px solid #E2E0D6;border-radius:8px;padding:10px 6px;text-align:center;cursor:pointer;width:100%;font-family:inherit;transition:all .15s}
.type-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.type-btn{background:#fff;border:1.5px solid #E2E0D6;border-radius:8px;padding:10px 6px;text-align:center;cursor:pointer;width:100%;font-family:inherit;transition:all .15s}
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid #E2E0D6}
.toggle-row:last-child{border-bottom:none}
.toggle{display:flex;gap:6px}
.toggle button{padding:4px 12px;border-radius:20px;font-size:11px;border:1px solid #E2E0D6;background:#fff;cursor:pointer;font-family:inherit}
.toggle button.on-yes{background:#E5F4EC;color:#136438;border-color:#A5D9BC}
.toggle button.on-no{background:#FBE8E8;color:#8A1A1A;border-color:#E8AAAA}
.user-info{background:#F8F2E3;border:1px solid #DFC98A;border-radius:8px;padding:10px 14px;margin-bottom:12px;font-size:12px;color:#B08D3C}
.tabs{display:flex;gap:0;margin-bottom:14px;border-bottom:1px solid #E2E0D6}
.tab{padding:8px 16px;font-size:12px;font-weight:500;cursor:pointer;border:none;background:transparent;color:#6B6960;font-family:inherit;border-bottom:2px solid transparent;margin-bottom:-1px}
.tab.on{color:#B08D3C;border-bottom-color:#B08D3C}
.warning-row td{background:#FDF2E0!important}
.critical-indicator{display:inline-block;width:6px;height:6px;border-radius:50%;background:#8A1A1A;margin-left:4px;vertical-align:middle}

@media(max-width:600px){.g2,.g3,.co-grid,.type-grid,.stats-grid,.kpi-grid{grid-template-columns:1fr 1fr}.wrap,.wrap-lg{padding:14px 12px}}
</style>
</head>
<body>

<nav>
  <div class="logo">Dam Jobs</div>
  <div class="nav-end">
    <span class="role-pill" id="nav-role"></span>
    <button class="back-btn" id="nav-back" onclick="goBack()">← رجوع</button>
    <button class="av-btn" id="nav-av" onclick="logout()" title="خروج">خ</button>
  </div>
</nav>

<!-- ===== LOGIN ===== -->
<div class="pg on" id="pg-login">
<div style="min-height:100vh;background:#1A1916;display:flex;align-items:center;justify-content:center;padding:16px">
  <div style="background:#fff;border-radius:14px;padding:32px;width:100%;max-width:380px;text-align:center">
    <div style="font-size:28px;font-weight:900;color:#B08D3C;letter-spacing:1px;margin-bottom:4px">Dam Jobs</div>
    <div style="font-size:11px;color:#6B6960;margin-bottom:24px">مجموعة دام القابضة — نظام التوظيف</div>
    <div class="f" style="text-align:right;margin-bottom:10px"><label>الإيميل</label><input id="li-email" type="email" placeholder="name@daamco.sa"></div>
    <div class="f" style="text-align:right;margin-bottom:12px"><label>كلمة المرور</label><input id="li-pass" type="password" placeholder="••••••••"></div>
    <div class="err" id="li-err">الإيميل أو كلمة المرور غير صحيحة</div>
    <button class="btn btn-gold" onclick="doLogin()">دخول ←</button>
    <div style="margin-top:14px;font-size:10px;color:#6B6960">للدعم: s.aldweesh@daamco.sa</div>
  </div>
</div>
</div>

<!-- ===== FORM: مدير الإدارة ===== -->
<div class="pg" id="pg-form">
<div class="wrap">
  <div class="user-info" id="form-user-info"></div>
  <div class="card">
    <div class="sec">🏢 الشركة *</div>
    <div class="co-grid">
      <button class="co-btn" id="co-daam"    onclick="pickCo('daam','دام القابضة','👑')"><div style="font-size:18px">👑</div><div style="font-size:10px;font-weight:600">دام القابضة</div></button>
      <button class="co-btn" id="co-rasf"    onclick="pickCo('rasf','رصف','🏗️')"><div style="font-size:18px">🏗️</div><div style="font-size:10px;font-weight:600">رصف</div></button>
      <button class="co-btn" id="co-arabyat" onclick="pickCo('arabyat','العربات الفاخرة','🚗')"><div style="font-size:18px">🚗</div><div style="font-size:10px;font-weight:600">العربات الفاخرة</div></button>
      <button class="co-btn" id="co-anawan"  onclick="pickCo('anawan','عناوان الضيافة','🏨')"><div style="font-size:18px">🏨</div><div style="font-size:10px;font-weight:600">عناوان الضيافة</div></button>
      <button class="co-btn" id="co-shatiba" onclick="pickCo('shatiba','شاطبة للمقاولات','🏚️')"><div style="font-size:18px">🏚️</div><div style="font-size:10px;font-weight:600">شاطبة</div></button>
      <button class="co-btn" id="co-mrkh"    onclick="pickCo('mrkh','مرخ للوجبات','🍽️')"><div style="font-size:18px">🍽️</div><div style="font-size:10px;font-weight:600">مرخ للوجبات</div></button>
      <button class="co-btn" id="co-maaqid"  onclick="pickCo('maaqid','معاقد للمقاولات','🔧')"><div style="font-size:18px">🔧</div><div style="font-size:10px;font-weight:600">معاقد</div></button>
      <button class="co-btn" id="co-manazil" onclick="pickCo('manazil','المنازل','🏠')"><div style="font-size:18px">🏠</div><div style="font-size:10px;font-weight:600">المنازل</div></button>
    </div>
  </div>
  <div class="card">
    <div class="sec">📌 نوع الطلب *</div>
    <div class="type-grid">
      <button class="type-btn" id="tt-new"     onclick="pickType('new','وظيفة جديدة')"><div style="font-size:18px">🆕</div><div style="font-size:10px;font-weight:600">وظيفة جديدة</div></button>
      <button class="type-btn" id="tt-replace" onclick="pickType('replace','استبدال موظف')"><div style="font-size:18px">🔄</div><div style="font-size:10px;font-weight:600">استبدال موظف</div></button>
      <button class="type-btn" id="tt-extra"   onclick="pickType('extra','زيادة احتياج')"><div style="font-size:18px">➕</div><div style="font-size:10px;font-weight:600">زيادة احتياج</div></button>
      <button class="type-btn" id="tt-temp"    onclick="pickType('temp','مؤقت/موسمي')"><div style="font-size:18px">⏳</div><div style="font-size:10px;font-weight:600">مؤقت/موسمي</div></button>
    </div>
  </div>
  <div class="card">
    <div class="sec">📄 بيانات الوظيفة</div>
    <div class="g2">
      <div class="f"><label>المسمى الوظيفي *</label><input id="f-title" placeholder="محاسب أول"></div>
      <div class="f"><label>الإدارة *</label><input id="f-dept" placeholder="الإدارة المالية"></div>
      <div class="f"><label>عدد الشواغر</label><input id="f-count" type="number" min="1" value="1"></div>
      <div class="f"><label>الراتب المتوقع</label><input id="f-salary" placeholder="8,000 ريال"></div>
      <div class="f"><label>موقع العمل</label><select id="f-loc"><option>الرياض</option><option>جدة</option><option>الدمام</option><option>مكة</option><option>المدينة</option><option>أخرى</option></select></div>
      <div class="f"><label>المؤهل والخبرة</label><select id="f-edu"><option>بكالوريوس + 3 سنوات</option><option>بكالوريوس + 5 سنوات</option><option>دبلوم</option><option>ماجستير</option><option>أي مؤهل</option></select></div>
      <div class="f"><label>السبب</label><select id="f-reason"><option>توسع في الأعمال</option><option>استقالة موظف</option><option>زيادة الأعباء</option><option>قسم جديد</option><option>نقل داخلي</option></select></div>
      <div class="f"><label>في الميزانية؟</label><select id="f-budget"><option>نعم — معتمدة</option><option>لا — تحتاج اعتماد</option><option>جزئياً</option></select></div>
    </div>
    <div class="f" style="margin-bottom:10px"><label>المهام الرئيسية</label><textarea id="f-tasks" placeholder="أبرز المهام..."></textarea></div>
    <div class="f" style="margin-bottom:10px"><label>أثر عدم التوظيف *</label><textarea id="f-impact" placeholder="ما الأثر على العمل؟"></textarea></div>
  </div>

  <!-- حقول جديدة: حرجة + توطين -->
  <div class="card">
    <div class="sec">⚡ تصنيف الوظيفة</div>
    <div class="toggle-row">
      <div>
        <div style="font-size:13px;font-weight:500">هل الوظيفة حرجة؟</div>
        <div style="font-size:11px;color:#6B6960;margin-top:2px">وظيفة حرجة = توقفها يؤثر على العمليات</div>
      </div>
      <div class="toggle" id="toggle-critical">
        <button id="crit-yes" onclick="setToggle('critical','yes')">نعم</button>
        <button id="crit-no" onclick="setToggle('critical','no')" class="on-no">لا</button>
      </div>
    </div>
    <div class="toggle-row">
      <div>
        <div style="font-size:13px;font-weight:500">مستهدفة بالتوطين؟</div>
        <div style="font-size:11px;color:#6B6960;margin-top:2px">وظيفة ضمن أهداف نطاقات / رؤية 2030</div>
      </div>
      <div class="toggle" id="toggle-saudization">
        <button id="saud-yes" onclick="setToggle('saudization','yes')">نعم</button>
        <button id="saud-no" onclick="setToggle('saudization','no')" class="on-no">لا</button>
      </div>
    </div>
  </div>

  <div class="err" id="form-err">يرجى تعبئة: الشركة، نوع الطلب، المسمى، الإدارة، الأثر.</div>
  <button class="btn btn-gold" onclick="submitForm()">📨 إرسال الطلب للموارد البشرية</button>
</div>
</div>

<!-- ===== SUCCESS ===== -->
<div class="pg" id="pg-ok">
<div class="wrap"><div class="suc">
  <div style="font-size:50px;margin-bottom:12px">📨</div>
  <div style="font-size:17px;font-weight:700;margin-bottom:6px">وصل طلبك بنجاح!</div>
  <div style="font-size:12px;color:#6B6960;margin-bottom:16px">سيتواصل معك مسؤول الموارد البشرية قريباً</div>
  <div style="background:#E5F4EC;border:1px solid #A5D9BC;border-radius:8px;padding:10px;display:inline-block;font-size:12px;color:#136438;margin-bottom:16px">رقم طلبك: <strong id="ok-id"></strong></div><br>
  <button class="btn btn-gray" style="width:auto;padding:8px 20px" onclick="goTo('form')">📋 طلب جديد</button>
</div></div>
</div>

<!-- ===== DASHBOARD HR ===== -->
<div class="pg" id="pg-dash">
<div class="wrap-lg">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px">
    <div><div style="font-size:17px;font-weight:700">داشبورد التوظيف</div><div style="font-size:11px;color:#6B6960" id="dash-date"></div></div>
    <div style="display:flex;gap:7px;flex-wrap:wrap">
      <button class="btn btn-wa btn-sm" onclick="goTo('wa')">📲 أرسل رابط</button>
      <button class="btn btn-gold btn-sm" onclick="goTo('cands')">👥 بنك المواهب</button>
      <button class="btn btn-blue btn-sm" onclick="goTo('critical')">⚡ الوظائف الحرجة</button>
      <button class="btn btn-green btn-sm" onclick="goTo('saudization')">🇸🇦 التوطين</button>
      <button class="btn btn-blue btn-sm" onclick="goTo('workforce')">📊 القوى العاملة</button>
      <button class="btn btn-gray btn-sm" onclick="goTo('hrops')">⚙️ HR Ops</button>
      <button class="btn btn-gray btn-sm" onclick="goTo('audit')">📋 Audit Log</button>
      <button class="btn btn-gold btn-sm" onclick="goTo('exec')" style="background:#1A1916;color:#B08D3C">👔 Executive Dashboard</button>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats-grid" id="dash-stats"></div>

  <!-- KPIs -->
