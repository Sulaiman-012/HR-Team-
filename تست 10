function calcTTF(R){var hired=R.filter(function(r){return r.status==='onboard'&&r.createdDate;});if(!hired.length)return 0;var total=hired.reduce(function(acc,r){return acc+daysSince(r.createdDate);},0);return Math.round(total/hired.length);}
