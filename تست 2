<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>منصة التوظيف — مجموعة دام القابضة</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F4F3EF;--card:#fff;--border:#E2E0D6;--text:#1A1916;--muted:#6B6960;
  --gold:#B08D3C;--gold-bg:#F8F2E3;--gold-bd:#DFC98A;
  --blue:#174E88;--blue-bg:#EAF1FB;--blue-bd:#B5D0EF;
  --green:#136438;--green-bg:#E5F4EC;--green-bd:#A5D9BC;
  --amber:#8A4E0C;--amber-bg:#FDF2E0;--amber-bd:#EDCA7A;
  --red:#8A1A1A;--red-bg:#FBEAEA;--red-bd:#E8AAAA;
  --purple:#3E1A7A;--purple-bg:#F0EAF8;--purple-bd:#C8A8E8;
  --r:10px;--r-sm:6px;--sh:0 1px 3px rgba(0,0,0,.05),0 1px 2px rgba(0,0,0,.04);
}
body{font-family:'IBM Plex Sans Arabic',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;line-height:1.5}

/* NAV */
.nav{background:var(--text);height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;position:sticky;top:0;z-index:100}
.brand{display:flex;align-items:center;gap:10px}
.logo{width:34px;height:34px;background:var(--gold);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;flex-shrink:0}
.brand-name{font-size:14px;font-weight:600;color:#fff}
.brand-sub{font-size:11px;color:rgba(255,255,255,.45)}
.nav-end{display:flex;align-items:center;gap:10px}
.role-pill{background:rgba(255,255,255,.1);color:rgba(255,255,255,.65);font-size:11px;padding:3px 10px;border-radius:20px;border:1px solid rgba(255,255,255,.15)}
.av{width:30px;height:30px;border-radius:50%;background:var(--gold);color:#fff;font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;cursor:pointer}

/* LAYOUT */
.pg{display:none}.pg.on{display:block}
.wrap{max-width:1100px;margin:0 auto;padding:26px 18px}
.wrap-sm{max-width:660px;margin:0 auto;padding:26px 18px}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:22px;box-shadow:var(--sh);margin-bottom:14px}

/* SECTION TITLE */
.st{font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.06em;padding-bottom:9px;border-bottom:1px solid var(--border);margin-bottom:14px;display:flex;align-items:center;gap:6px}

/* FORM */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:13px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px;margin-bottom:13px}
.fc{grid-column:1/-1}
.f{display:flex;flex-direction:column;gap:4px}
.f label{font-size:12px;font-weight:500;color:var(--muted)}
.f input,.f select,.f textarea{font-size:13px;padding:8px 11px;border:1px solid var(--border);border-radius:var(--r-sm);background:#fff;color:var(--text);font-family:inherit;width:100%;transition:border-color .15s}
.f input:focus,.f select:focus,.f textarea:focus{outline:none;border-color:var(--gold)}
.f textarea{min-height:68px;resize:vertical}
.req{color:var(--red);font-size:9px;margin-right:2px}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:8px 16px;border-radius:var(--r-sm);font-size:13px;font-weight:500;cursor:pointer;border:1px solid transparent;font-family:inherit;transition:all .15s;text-decoration:none}
.btn-gold{background:var(--gold);color:#fff;border-color:var(--gold)}.btn-gold:hover{background:#9A7A30}
.btn-out{background:transparent;color:var(--text);border-color:var(--border)}.btn-out:hover{background:var(--bg)}
.btn-blue{background:var(--blue);color:#fff}.btn-blue:hover{background:#113C6E}
.btn-green{background:var(--green);color:#fff}.btn-green:hover{background:#0D4E2C}
.btn-red{background:var(--red);color:#fff}.btn-red:hover{background:#6E1414}
.btn-wa{background:#25D366;color:#fff;border-color:#25D366}.btn-wa:hover{background:#1CB857}
.btn-full{width:100%;justify-content:center;padding:11px}
.btn-sm{padding:5px 11px;font-size:11px}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:2px 8px;border-radius:20px;font-weight:500;white-space:nowrap}
.b-blue{background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue-bd)}
.b-gold{background:var(--gold-bg);color:var(--gold);border:1px solid var(--gold-bd)}
.b-green{background:var(--green-bg);color:var(--green);border:1px solid var(--green-bd)}
.b-amber{background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber-bd)}
.b-red{background:var(--red-bg);color:var(--red);border:1px solid var(--red-bd)}
.b-purple{background:var(--purple-bg);color:var(--purple);border:1px solid var(--purple-bd)}
.b-gray{background:#EFEDE6;color:#666;border:1px solid var(--border)}

/* STATS */
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:11px;margin-bottom:22px}
.stat{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px}
.stat-n{font-size:26px;font-weight:700;line-height:1;margin-bottom:3px}
.stat-l{font-size:11px;color:var(--muted)}

/* TABLE */
.tbl{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:right;padding:9px 12px;border-bottom:1px solid var(--border);font-size:11px;font-weight:600;color:var(--muted);white-space:nowrap;background:#FAFAF6}
td{padding:9px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#FAFAF6}

/* COMPANY GRID */
.co-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;margin-bottom:14px}
.co-card{border:1.5px solid var(--border);border-radius:var(--r);padding:13px 10px;text-align:center;cursor:pointer;background:#fff;transition:all .15s}
.co-card:hover{border-color:var(--gold);background:var(--gold-bg)}
.co-card.sel{border-color:var(--gold);background:var(--gold-bg);box-shadow:0 0 0 3px rgba(176,141,60,.15)}
.co-ico{font-size:20px;margin-bottom:5px}
.co-nm{font-size:11px;font-weight:600;margin-bottom:2px}
.co-tp{font-size:10px;color:var(--muted)}

/* ROLE GRID */
.role-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin-bottom:16px}
.role-card{border:1.5px solid var(--border);border-radius:var(--r);padding:18px 14px;text-align:center;cursor:pointer;background:#fff;transition:all .15s}
.role-card:hover{border-color:var(--blue);background:var(--blue-bg)}
.role-ico{font-size:26px;margin-bottom:8px}
.role-nm{font-size:13px;font-weight:600;margin-bottom:4px}
.role-ds{font-size:11px;color:var(--muted);line-height:1.5}

/* STEPPER */
.stepper{display:flex;overflow-x:auto;padding-bottom:4px;margin-bottom:18px}
.stp{flex:1;min-width:72px;display:flex;flex-direction:column;align-items:center;gap:4px;position:relative}
.stp:not(:last-child)::after{content:'';position:absolute;top:12px;left:0;width:50%;height:1.5px;background:var(--border)}
.stp:not(:first-child)::before{content:'';position:absolute;top:12px;right:0;width:50%;height:1.5px;background:var(--border)}
.stp.done::after,.stp.done::before,.stp.cur::before{background:var(--gold)}
.stp-d{width:24px;height:24px;border-radius:50%;border:1.5px solid var(--border);background:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;z-index:1;position:relative;color:var(--muted)}
.stp.done .stp-d{background:var(--gold);border-color:var(--gold);color:#fff}
.stp.cur .stp-d{background:var(--blue);border-color:var(--blue);color:#fff;box-shadow:0 0 0 3px var(--blue-bg)}
.stp-l{font-size:9px;color:var(--muted);text-align:center;line-height:1.3;max-width:68px}
.stp.cur .stp-l{color:var(--blue);font-weight:600}
.stp.done .stp-l{color:var(--green)}

/* TIMELINE */
.tl{display:flex;flex-direction:column}
.tl-row{display:flex;gap:11px;padding:7px 0;position:relative}
.tl-row:not(:last-child)::after{content:'';position:absolute;right:13px;top:30px;bottom:0;width:1.5px;background:var(--border)}
.tl-dot{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;border:1px solid var(--border)}
.tl-body{flex:1;padding-top:2px}
.tl-ti{font-size:12px;font-weight:500}
.tl-su{font-size:11px;color:var(--muted);margin-top:2px}

/* DETAIL ROW */
.dr{display:flex;justify-content:space-between;align-items:flex-start;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px}
.dr:last-child{border-bottom:none}
.dl{color:var(--muted);font-size:11px;min-width:130px;flex-shrink:0}
.dv{color:var(--text);flex:1;text-align:left;font-size:12px}

/* WA BOX */
.wa-box{background:var(--green-bg);border:1px solid var(--green-bd);border-radius:var(--r);padding:13px}
.wa-msg{font-size:11px;color:var(--green);line-height:1.8;white-space:pre-wrap;word-break:break-all;font-family:monospace}

/* PAGE HEADER */
.ph{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;gap:12px;flex-wrap:wrap}
.ph-title{font-size:19px;font-weight:700}
.ph-sub{font-size:12px;color:var(--muted);margin-top:3px}

/* FILTERS */
.filters{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px}
.fb{padding:5px 13px;border-radius:20px;border:1px solid var(--border);background:#fff;font-size:11px;cursor:pointer;font-family:inherit;color:var(--muted);transition:all .15s}
.fb:hover,.fb.on{background:var(--text);color:#fff;border-color:var(--text)}

/* SUCCESS */
.suc{text-align:center;padding:44px 20px}

/* EMPTY */
.empty{text-align:center;padding:36px;color:var(--muted);font-size:13px}

/* AI BOX */
.ai-box{background:var(--blue-bg);border:1px solid var(--blue-bd);border-radius:var(--r);padding:13px;margin-top:10px}
.ai-txt{font-size:12px;color:var(--blue);line-height:1.8;white-space:pre-wrap}

/* NOTIFY */
.notif{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:var(--text);color:#fff;padding:9px 20px;border-radius:8px;font-size:12px;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap}
.notif.show{opacity:1}

/* CANDIDATE TABLE */
.c-tag{font-size:10px;padding:2px 7px;border-radius:4px;border:1px solid var(--border);color:var(--muted);margin:1px}

@media(max-width:600px){
  .co-grid{grid-template-columns:1fr 1fr}
  .role-grid{grid-template-columns:1fr}
  .g2,.g3{grid-template-columns:1fr}
  .stats{grid-template-columns:1fr 1fr}
  .wrap,.wrap-sm{padding:14px 12px}
  .nav{padding:0 12px}
}
</style>
</head>
<body>

<!-- LOGIN -->
<div class="pg on" id="pg-login">
  <div style="min-height:100vh;background:var(--text);display:flex;align-items:center;justify-content:center;padding:20px">
    <div style="background:#fff;border-radius:16px;padding:38px;width:100%;max-width:400px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.18)">
      <div style="width:60px;height:60px;background:var(--gold);border-radius:14px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;color:#fff">د</div>
      <div style="font-size:20px;font-weight:700;margin-bottom:5px">منصة التوظيف</div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:24px;line-height:1.7">مجموعة دام القابضة<br>أدخل إيميل الشركة للدخول</div>
      <div class="f" style="text-align:right;margin-bottom:13px">
        <label>إيميل الشركة</label>
        <input id="login-email" type="email" placeholder="name@daamco.sa">
      </div>
      <div id="login-err" style="display:none;background:var(--red-bg);border:1px solid var(--red-bd);border-radius:6px;padding:8px 11px;font-size:12px;color:var(--red);margin-bottom:11px;text-align:right">
        ⚠️ يرجى استخدام إيميل الشركة (@daamco.sa)
      </div>
      <button class="btn btn-gold btn-full" type="button" onclick="(function(){var e=document.getElementById('login-email').value.trim();if(!e){document.getElementById('login-err').style.display='block';return;}document.getElementById('login-err').style.display='none';window._user=e;document.getElementById('nav-av').textContent=e.charAt(0).toUpperCase();document.getElementById('main-nav').style.display='block';var pgs=document.querySelectorAll('.pg');for(var i=0;i<pgs.length;i++)pgs[i].classList.remove('on');document.getElementById('pg-role').classList.add('on');})()">دخول ←</button>
      <div style="margin-top:14px;font-size:11px;color:var(--muted)">للدعم: hr@daamco.sa</div>
    </div>
  </div>
</div>

<!-- NAV (hidden until login) -->
<div id="main-nav" style="display:none">
  <nav class="nav">
    <div class="brand">
      <div class="logo">د</div>
      <div><div class="brand-name">منصة التوظيف</div><div class="brand-sub">مجموعة دام القابضة</div></div>
    </div>
    <div class="nav-end">
      <span class="role-pill" id="nav-role">—</span>
      <div class="av" id="nav-av" onclick="logout()" title="خروج">خ</div>
    </div>
  </nav>
</div>

<!-- ROLE SELECT -->
<div class="pg" id="pg-role">
  <div class="wrap-sm">
    <div style="text-align:center;padding:22px 0 18px">
      <div style="font-size:19px;font-weight:700;margin-bottom:5px">مرحباً 👋</div>
      <div style="font-size:12px;color:var(--muted)">اختر دورك للمتابعة</div>
    </div>
    <div class="role-grid">
      <div class="role-card" data-role="hr" onclick="setRole('hr')">
        <div class="role-ico">🎯</div>
        <div class="role-nm">الموارد البشرية</div>
        <div class="role-ds">داشبورد كامل — إدارة جميع طلبات المجموعة</div>
      </div>
      <div class="role-card" data-role="manager" onclick="setRole('manager')">
        <div class="role-ico">📋</div>
        <div class="role-nm">مدير الإدارة</div>
        <div class="role-ds">تقديم طلب فتح وظيفة جديدة</div>
      </div>
      <div class="role-card" data-role="finance" onclick="setRole('finance')">
        <div class="role-ico">💰</div>
        <div class="role-nm">الإدارة المالية</div>
        <div class="role-ds">مراجعة واعتماد طلبات التوظيف</div>
      </div>
    </div>
  </div>
</div>

<!-- DASHBOARD HR -->
<div class="pg" id="pg-dash">
  <div class="wrap">
    <div class="ph">
      <div><div class="ph-title">داشبورد التوظيف</div><div class="ph-sub" id="dash-date"></div></div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-wa btn-sm" onclick="goTo('wa-send')">📲 أرسل رابط لمدير</button>
        <button class="btn btn-gold btn-sm" onclick="goTo('candidates')">👥 بنك المرشحين</button>
        <button class="btn btn-out btn-sm" onclick="goTo('form')">+ طلب جديد</button>
      </div>
    </div>

    <div class="stats">
      <div class="stat"><div class="stat-n" id="s0">0</div><div class="stat-l">إجمالي الطلبات</div></div>
      <div class="stat"><div class="stat-n" style="color:var(--amber)" id="s1">0</div><div class="stat-l">بانتظار الإجراء</div></div>
      <div class="stat"><div class="stat-n" style="color:var(--blue)" id="s2">0</div><div class="stat-l">جاري التوظيف</div></div>
      <div class="stat"><div class="stat-n" style="color:var(--green)" id="s3">0</div><div class="stat-l">تم التوظيف</div></div>
      <div class="stat"><div class="stat-n" style="color:var(--red)" id="s4">0</div><div class="stat-l">مغلق/مرفوض</div></div>
      <div class="stat"><div class="stat-n" style="color:var(--purple)" id="s5">0</div><div class="stat-l">مرشحون في البنك</div></div>
    </div>

    <!-- شركات -->
    <div class="card">
      <div class="st">🏢 الطلبات حسب الشركة</div>
      <div id="co-stat-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:9px"></div>
    </div>

    <!-- طلبات -->
    <div class="card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:11px;flex-wrap:wrap;gap:8px">
        <div class="st" style="margin:0;border:none;padding:0">📋 الطلبات</div>
        <div class="filters" style="margin:0" id="dash-filters"></div>
      </div>
      <div class="tbl"><table>
        <thead><tr><th>رقم</th><th>المسمى</th><th>الشركة</th><th>الإدارة</th><th>نوع الطلب</th><th>الحالة</th><th>التاريخ</th><th>إجراء</th></tr></thead>
        <tbody id="req-tbody"></tbody>
      </table></div>
    </div>
  </div>
</div>

<!-- FORM: مدير الإدارة -->
<div class="pg" id="pg-form">
  <div class="wrap-sm">
    <div class="ph">
      <div>
        <div style="font-size:11px;color:var(--muted);margin-bottom:3px">مجموعة دام القابضة</div>
        <div class="ph-title">طلب فتح وظيفة</div>
        <div class="ph-sub">ستصل للموارد البشرية فوراً بعد الإرسال</div>
      </div>
      <button class="btn btn-out btn-sm" onclick="goBack()">رجوع</button>
    </div>

    <!-- اختيار الشركة -->
    <div class="card">
      <div class="st">🏢 الشركة <span class="req">*</span></div>
      <div class="co-grid" id="co-sel"></div>
    </div>

    <!-- نوع الطلب -->
    <div class="card">
      <div class="st">📌 نوع الطلب <span class="req">*</span></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:0" id="req-type-grid">
        <div class="co-card" id="rt-new"     onclick="selType('new')">     <div style="font-size:18px;margin-bottom:5px">🆕</div><div style="font-size:12px;font-weight:600">وظيفة جديدة</div></div>
        <div class="co-card" id="rt-replace" onclick="selType('replace')"> <div style="font-size:18px;margin-bottom:5px">🔄</div><div style="font-size:12px;font-weight:600">استبدال موظف</div></div>
        <div class="co-card" id="rt-extra"   onclick="selType('extra')">   <div style="font-size:18px;margin-bottom:5px">➕</div><div style="font-size:12px;font-weight:600">زيادة احتياج</div></div>
        <div class="co-card" id="rt-temp"    onclick="selType('temp')">    <div style="font-size:18px;margin-bottom:5px">⏳</div><div style="font-size:12px;font-weight:600">مؤقت / موسمي</div></div>
      </div>
    </div>

    <!-- بيانات الوظيفة -->
    <div class="card">
      <div class="st">📄 بيانات الوظيفة</div>
      <div class="g2">
        <div class="f"><label>المسمى الوظيفي <span class="req">*</span></label><input id="f-title" placeholder="محاسب أول" oninput="clearAI()"></div>
        <div class="f"><label>الإدارة / القسم <span class="req">*</span></label><input id="f-dept" placeholder="الإدارة المالية"></div>
        <div class="f"><label>عدد الشواغر <span class="req">*</span></label><input id="f-count" type="number" min="1" value="1"></div>
        <div class="f"><label>الراتب المتوقع (ريال)</label><input id="f-salary" placeholder="8,000"></div>
        <div class="f"><label>موقع العمل</label>
          <select id="f-location"><option>الرياض</option><option>جدة</option><option>الدمام</option><option>مكة المكرمة</option><option>المدينة المنورة</option><option>أخرى</option></select>
        </div>
        <div class="f"><label>تاريخ الحاجة</label><input id="f-date" type="date"></div>
        <div class="f"><label>المؤهل والخبرة</label>
          <select id="f-edu"><option>بكالوريوس + 3 سنوات</option><option>بكالوريوس + 5 سنوات</option><option>دبلوم</option><option>ماجستير</option><option>أي مؤهل</option></select>
        </div>
        <div class="f"><label>السبب</label>
          <select id="f-reason"><option>توسع في الأعمال</option><option>استقالة موظف</option><option>زيادة أعباء العمل</option><option>قسم جديد</option><option>نقل داخلي</option></select>
