<script>
const COMPANIES=[
  {id:'daam',    name:'دام القابضة',      icon:'👑',type:'الشركة الأم'},
  {id:'rasf',    name:'رصف',              icon:'🏗️',type:'مقاولات'},
  {id:'arabyat', name:'العربات الفاخرة',  icon:'🚗',type:'سيارات فاخرة'},
  {id:'anawan',  name:'عناوان الضيافة',   icon:'🏨',type:'ضيافة'},
  {id:'shatiba', name:'شاطبة للمقاولات', icon:'🏚️',type:'مقاولات'},
  {id:'mrkh',    name:'مرخ للوجبات',      icon:'🍽️',type:'مطاعم'},
  {id:'maaqid',  name:'معاقد للمقاولات', icon:'🔧',type:'مقاولات'},
  {id:'manazil', name:'المنازل',          icon:'🏠',type:'عقارات'},
];

const REQ_TYPES={new:'وظيفة جديدة',replace:'استبدال موظف',extra:'زيادة احتياج',temp:'مؤقت/موسمي'};

const STATUSES=[
  {id:'received', label:'تم الاستلام',       cls:'b-blue'},
  {id:'fin_wait', label:'بانتظار المالية',    cls:'b-amber'},
  {id:'approved', label:'معتمد',              cls:'b-green'},
  {id:'searching',label:'جاري البحث',         cls:'b-purple'},
  {id:'shortlist',label:'ترشيح مرشحين',       cls:'b-purple'},
  {id:'int1',     label:'مقابلة أولى',        cls:'b-purple'},
  {id:'int2',     label:'مقابلة فنية',        cls:'b-purple'},
  {id:'offer',    label:'عرض وظيفي',          cls:'b-gold'},
  {id:'hired',    label:'تم التوظيف',         cls:'b-green'},
  {id:'closed',   label:'مغلق/مرفوض',        cls:'b-gray'},
];

const CAND_STATUS_CLS={جديد:'b-blue','تحت الدراسة':'b-amber','مقابلة أولى':'b-purple','مقابلة نهائية':'b-purple','عرض وظيفي':'b-gold','تم التوظيف':'b-green','غير مناسب':'b-gray',احتياط:'b-blue'};

const SK='daam_v2';
let DB={requests:[],candidates:[]};
let user=null,role=null,curId=null,filterCo='all';
let selCo=null,selType=null;

function loadDB(){try{const d=localStorage.getItem(SK);if(d)DB=JSON.parse(d)}catch{}}
function saveDB(){try{localStorage.setItem(SK,JSON.stringify(DB))}catch{}}
function v(id){return(document.getElementById(id)||{}).value||''}
function today(){return new Date().toLocaleDateString('ar-SA',{year:'numeric',month:'short',day:'numeric'})}
function uid(){return'JR-'+Date.now().toString().slice(-6)}
function notify(msg){const n=document.getElementById('notif');n.textContent=msg;n.classList.add('show');setTimeout(()=>n.classList.remove('show'),2500)}
function getSt(id){return STATUSES.find(s=>s.id===id)||STATUSES[0]}

function goTo(pg){
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('on'));
  const el=document.getElementById('pg-'+pg);
  if(el)el.classList.add('on');
  if(pg==='dash')renderDash();
  if(pg==='fin')renderFinList();
  if(pg==='candidates')renderCandidates();
  if(pg==='wa-send')refreshWA();
  if(pg==='form'){selCo=null;selType=null;renderCoSel();renderTypeSel();}
  window.scrollTo(0,0);
}
function goBack(){role==='hr'?goTo('dash'):goTo('role')}

// AUTH
function doLogin(){
  const e=v('login-email').trim();
  if(!e){
    document.getElementById('login-err').style.display='block';
    document.getElementById('login-err').textContent='⚠️ يرجى إدخال الإيميل للمتابعة';
    return;
  }
  document.getElementById('login-err').style.display='none';
  user=e;
  const nm=e.split('@')[0];
  document.getElementById('nav-av').textContent=nm.charAt(0).toUpperCase();
  document.getElementById('main-nav').style.display='block';
  loadDB();
  goTo('role');
}
function logout(){user=null;role=null;document.getElementById('main-nav').style.display='none';goTo('login')}

// ROLE
function setRole(r){
  role=r;
  const lbl={hr:'الموارد البشرية',manager:'مدير الإدارة',finance:'الإدارة المالية'};
  document.getElementById('nav-role').textContent=lbl[r]||r;
  if(r==='hr')goTo('dash');
  else if(r==='manager')goTo('form');
  else goTo('fin');
}

// COMPANY SELECTOR
function renderCoSel(){
  const w=document.getElementById('co-sel');
  w.innerHTML=COMPANIES.map(c=>`<div class="co-card" id="co-${c.id}" onclick="pickCo('${c.id}')"><div class="co-ico">${c.icon}</div><div class="co-nm">${c.name}</div><div class="co-tp">${c.type}</div></div>`).join('');
}
function pickCo(id){
  selCo=id;
  document.querySelectorAll('.co-card').forEach(c=>c.classList.remove('sel'));
  const el=document.getElementById('co-'+id);if(el)el.classList.add('sel');
}

// TYPE SELECTOR
function renderTypeSel(){selType=null;document.querySelectorAll('[id^=rt-]').forEach(e=>e.classList.remove('sel'))}
function selType(t){
  selType=t;
  document.querySelectorAll('[id^=rt-]').forEach(e=>e.classList.remove('sel'));
  const el=document.getElementById('rt-'+t);if(el)el.classList.add('sel');
}

// AI JD GENERATOR
function clearAI(){document.getElementById('ai-box').style.display='none'}
function genJD(){
  const title=v('f-title').trim();
  if(!title){notify('أدخل المسمى الوظيفي أولاً');return}
  const co=COMPANIES.find(c=>c.id===selCo);
  const coName=co?co.name:'الشركة';
  const jdTemplates={
    default:`المسمى الوظيفي: ${title}\nالشركة: ${coName}\n\nالمهام والمسؤوليات:\n• تنفيذ المهام اليومية المتعلقة بالمسمى الوظيفي بدقة واحترافية\n• التنسيق مع الفرق ذات العلاقة لضمان سير العمل\n• إعداد التقارير الدورية ورفعها للمدير المباشر\n• المشاركة في تطوير الإجراءات وتحسين الكفاءة التشغيلية\n• الالتزام بسياسات وأنظمة الشركة\n\nالمتطلبات:\n• مؤهل علمي مناسب في التخصص ذي الصلة\n• خبرة لا تقل عن 2-3 سنوات في مجال مشابه\n• مهارات تواصل وعمل ضمن فريق\n• إجادة برامج Office\n• يفضل حاملي الجنسية السعودية`,
  };
  const words=title.toLowerCase();
  let jd=jdTemplates.default;
  if(words.includes('محاسب')||words.includes('مالي')){
    jd=`المسمى الوظيفي: ${title}\nالشركة: ${coName}\n\nالمهام والمسؤوليات:\n• تسجيل القيود المحاسبية اليومية وإجراء التسويات البنكية\n• إعداد القوائم المالية الشهرية والربع سنوية\n• متابعة الذمم المدينة والدائنة والمطابقة مع الموردين\n• إعداد تقارير ضريبة القيمة المضافة وتقديمها في المواعيد المحددة\n• المشاركة في إعداد الميزانية التقديرية السنوية\n• التنسيق مع المراجعين الخارجيين\n\nالمتطلبات:\n• بكالوريوس محاسبة أو مالية\n• خبرة 3-5 سنوات في بيئة محاسبية\n• إلمام بأنظمة الزكاة والضريبة في المملكة\n• إجادة Excel ويفضل معرفة بـ SAP أو Oracle\n• يفضل حامل شهادة SOCPA\n• سعودي الجنسية (وظيفة مستهدفة للتوطين)`;
  }else if(words.includes('مهندس')||words.includes('هندس')){
    jd=`المسمى الوظيفي: ${title}\nالشركة: ${coName}\n\nالمهام والمسؤوليات:\n• الإشراف على تنفيذ المشاريع الهندسية ومتابعة سير الأعمال\n• مراجعة المخططات والمواصفات الفنية والتأكد من الجودة\n• إعداد التقارير اليومية والأسبوعية عن تقدم المشاريع\n• التنسيق مع المقاولين من الباطن وفرق العمل الميدانية\n• الالتزام بمعايير السلامة والجودة المعتمدة\n\nالمتطلبات:\n• بكالوريوس هندسة في التخصص المطلوب\n• خبرة 3-5 سنوات في مشاريع مشابهة\n• عضوية هيئة المهندسين السعوديين ميزة\n• إجادة AutoCAD وبرامج الهندسة\n• يفضل سعودي الجنسية`;
  }
  document.getElementById('ai-txt').textContent=jd;
  document.getElementById('ai-box').style.display='block';
  notify('✨ تم توليد الوصف الوظيفي');
  if(!v('f-tasks'))document.getElementById('f-tasks').value=jd;
}

// SUBMIT FORM
function submitForm(){
  if(!selCo||!selType||!v('f-title')||!v('f-dept')||!v('f-impact')||!v('f-sub')){
    document.getElementById('form-err').style.display='block';return;
  }
  document.getElementById('form-err').style.display='none';
  loadDB();
  const co=COMPANIES.find(c=>c.id===selCo);
  const id=uid();
  const rec={
    id,coId:selCo,coName:co?.name,coIcon:co?.icon,
    reqType:selType,reqTypeLabel:REQ_TYPES[selType],
    status:'received',time:today(),
    title:v('f-title'),dept:v('f-dept'),count:v('f-count'),salary:v('f-salary'),
    location:v('f-location'),date:v('f-date'),edu:v('f-edu'),reason:v('f-reason'),
    budget:v('f-budget'),jd:v('f-jd'),tasks:v('f-tasks'),impact:v('f-impact'),notes:v('f-notes'),
    sub:v('f-sub'),phone:v('f-phone'),email:v('f-email'),
    log:[{t:'تم استلام الطلب',s:v('f-sub')+' — '+today(),c:'blue'}]
  };
  DB.requests.push(rec);saveDB();
  document.getElementById('ok-id').textContent=id;
  goTo('ok');
}

// DASHBOARD
function renderDash(){
  loadDB();
  document.getElementById('dash-date').textContent=today();
  const R=DB.requests,C=DB.candidates||[];
  const pending=R.filter(r=>['received','fin_wait'].includes(r.status)).length;
  const prog=R.filter(r=>['approved','searching','shortlist','int1','int2','offer'].includes(r.status)).length;
  document.getElementById('s0').textContent=R.length;
  document.getElementById('s1').textContent=pending;
  document.getElementById('s2').textContent=prog;
  document.getElementById('s3').textContent=R.filter(r=>r.status==='hired').length;
  document.getElementById('s4').textContent=R.filter(r=>r.status==='closed').length;
  document.getElementById('s5').textContent=C.length;

  document.getElementById('co-stat-grid').innerHTML=COMPANIES.map(c=>{
    const n=R.filter(r=>r.coId===c.id).length;
    return`<div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 10px;display:flex;align-items:center;gap:8px;cursor:pointer" onclick="filterDash('${c.id}')">
      <span style="font-size:16px">${c.icon}</span>
      <div><div style="font-size:11px;font-weight:600">${c.name}</div><div style="font-size:10px;color:var(--muted)">${n} طلب</div></div>
    </div>`;
  }).join('');

  const filt=document.getElementById('dash-filters');
  filt.innerHTML=`<button class="fb ${filterCo==='all'?'on':''}" onclick="filterDash('all')">الكل</button>`+
    COMPANIES.filter(c=>R.some(r=>r.coId===c.id)).map(c=>`<button class="fb ${filterCo===c.id?'on':''}" onclick="filterDash('${c.id}')">${c.icon} ${c.name}</button>`).join('');

  const rows=filterCo==='all'?R:R.filter(r=>r.coId===filterCo);
  const tbody=document.getElementById('req-tbody');
  if(!rows.length){tbody.innerHTML=`<tr><td colspan="8"><div class="empty">📂 لا توجد طلبات بعد</div></td></tr>`;return;}
  tbody.innerHTML=[...rows].reverse().map(r=>{
    const st=getSt(r.status);
    return`<tr>
      <td style="font-family:monospace;font-size:10px;color:var(--muted)">${r.id}</td>
      <td style="font-weight:500">${r.title}</td>
      <td>${r.coIcon} ${r.coName}</td>
      <td style="color:var(--muted)">${r.dept}</td>
      <td><span style="font-size:10px;color:var(--muted)">${r.reqTypeLabel||'—'}</span></td>
      <td><span class="badge ${st.cls}">${st.label}</span></td>
      <td style="font-size:10px;color:var(--muted)">${r.time}</td>
      <td><div style="display:flex;gap:5px;flex-wrap:wrap">
        <button class="btn btn-out btn-sm" onclick="openDetail('${r.id}')">👁 عرض</button>
        ${r.status==='received'?`<button class="btn btn-wa btn-sm" onclick="openDetail('${r.id}')">💰 للمالية</button>`:''}
      </div></td>
    </tr>`;
  }).join('');
}
function filterDash(co){filterCo=co;renderDash()}

// DETAIL
function openDetail(id){
  loadDB();const r=DB.requests.find(x=>x.id===id);if(!r)return;curId=id;
  document.getElementById('det-title').textContent=r.title;
  document.getElementById('det-sub').textContent=r.id+' | '+r.coIcon+' '+r.coName+' | '+r.dept;

  const stIds=STATUSES.map(s=>s.id);
  const ci=stIds.indexOf(r.status);
  document.getElementById('det-stepper').innerHTML=STATUSES.map((s,i)=>{
    const cls=i<ci?'stp done':i===ci?'stp cur':'stp';
    return`<div class="${cls}"><div class="stp-d">${i<ci?'✓':i+1}</div><div class="stp-l">${s.label}</div></div>`;
  }).join('');

  if(role==='hr'){
    const nxt=STATUSES.filter((_,i)=>i>ci);
    document.getElementById('det-status-act').innerHTML=nxt.length?`<div style="display:flex;gap:7px;flex-wrap:wrap;align-items:center"><span style="font-size:11px;color:var(--muted)">تحديث الحالة:</span>${nxt.slice(0,4).map(s=>`<button class="btn btn-out btn-sm" onclick="chSt('${r.id}','${s.id}')">${s.label}</button>`).join('')}</div>`:'';
  }else{document.getElementById('det-status-act').innerHTML=''}

  const rows=[
    ['الشركة',r.coIcon+' '+r.coName],['الإدارة',r.dept],['المسمى',r.title],
    ['نوع الطلب',r.reqTypeLabel||'—'],['الشواغر',r.count],['الراتب',r.salary||'—'],
    ['موقع العمل',r.location||'—'],['تاريخ الحاجة',r.date||'—'],
    ['المؤهل',r.edu],['السبب',r.reason],['في الميزانية',r.budget],
    ['المهام',r.tasks||'—'],['الأثر',r.impact],['ملاحظات',r.notes||'—'],
    ['مقدم الطلب',r.sub],['الجوال',r.phone||'—'],['الإيميل',r.email||'—'],['التاريخ',r.time],
    ...(r.finName?[['اعتماد المالية',r.finName],['ملاحظات المالية',r.finNotes||'—']]:[]
    )];
  document.getElementById('det-body').innerHTML=rows.map(([l,val])=>`<div class="dr"><span class="dl">${l}</span><span class="dv">${val||'—'}</span></div>`).join('');

  const fc=document.getElementById('det-fin-card');
  if(r.status==='received'&&role==='hr'){
    fc.style.display='block';
    document.getElementById('det-wa-msg').textContent=buildFinMsg(r);
  }else{fc.style.display='none'}

  document.getElementById('det-tl').innerHTML=(r.log||[]).map(l=>`<div class="tl-row"><div class="tl-dot" style="background:var(--${l.c||'blue'}-bg);color:var(--${l.c||'blue'})">✓</div><div class="tl-body"><div class="tl-ti">${l.t}</div><div class="tl-su">${l.s}</div></div></div>`).join('');
  goTo('detail');
}

function chSt(id,ns){
  loadDB();const r=DB.requests.find(x=>x.id===id);if(!r)return;
  const st=getSt(ns);r.status=ns;
  r.log.push({t:'تحديث: '+st.label,s:'الموارد البشرية — '+today(),c:'blue'});
  if(ns==='fin_wait')r.log.push({t:'أُرسل للإدارة المالية',s:'الموارد البشرية — '+today(),c:'amber'});
  saveDB();notify('تم تحديث: '+st.label);openDetail(id);
}

function buildFinMsg(r){
  return`مرحباً،\n\nيرجى مراجعة واعتماد طلب الاحتياج الوظيفي:\n\nالوظيفة: ${r.title}\nالشركة: ${r.coName}\nالإدارة: ${r.dept}\nعدد الشواغر: ${r.count}\nالراتب: ${r.salary||'—'}\nفي الميزانية: ${r.budget}\n\nالرقم المرجعي: ${r.id}\nمقدم الطلب: ${r.sub}\n\nافتح المنصة واختر "الإدارة المالية" ثم ابحث عن رقم الطلب.\n\nشكراً،\nالموارد البشرية — دام القابضة`;
}
function copyDetWA(){
  navigator.clipboard.writeText(document.getElementById('det-wa-msg').textContent).catch(()=>{});
  document.getElementById('copy-det-wa').textContent='✓ تم النسخ';
  setTimeout(()=>{document.getElementById('copy-det-wa').textContent='📋 نسخ'},2000);
  notify('تم النسخ');
}
function openDetWA(){
  window.open('https://wa.me/?text='+encodeURIComponent(document.getElementById('det-wa-msg').textContent),'_blank');
  loadDB();const r=DB.requests.find(x=>x.id===curId);
  if(r&&r.status==='received'){r.status='fin_wait';r.log.push({t:'أُرسل للإدارة المالية',s:'الموارد البشرية — '+today(),c:'amber'});saveDB();}
}

// FINANCE
function renderFinList(){
  loadDB();
  const pend=DB.requests.filter(r=>['fin_wait','received'].includes(r.status));
  const done=DB.requests.filter(r=>['approved','closed'].includes(r.status));
  let html='';
  if(!pend.length&&!done.length){html=`<div class="card"><div class="empty">📂 لا توجد طلبات</div></div>`}
  else{
    if(pend.length){
      html+=`<div class="card"><div class="st">⏳ بانتظار الاعتماد (${pend.length})</div>`+
      pend.map(r=>`<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);gap:8px;flex-wrap:wrap">
        <div><div style="font-weight:500;font-size:13px">${r.coIcon} ${r.title}</div><div style="font-size:11px;color:var(--muted)">${r.coName} — ${r.dept} — ${r.count} شاغر — ${r.time}</div></div>
        <button class="btn btn-gold btn-sm" onclick="openFinDet('${r.id}')">مراجعة واعتماد</button>
      </div>`).join('')+'</div>';
    }
    if(done.length){
      html+=`<div class="card"><div class="st">✅ تم البت بها (${done.length})</div>`+
      done.map(r=>{const st=getSt(r.status);return`<div style="display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border)">
        <span style="font-size:12px">${r.coIcon} ${r.title} <span style="color:var(--muted);font-size:10px">— ${r.coName}</span></span>
        <span class="badge ${st.cls}">${st.label}</span>
      </div>`}).join('')+'</div>';
    }
  }
  document.getElementById('fin-list').innerHTML=html;
}

function openFinDet(id){
  loadDB();const r=DB.requests.find(x=>x.id===id);if(!r)return;curId=id;
  document.getElementById('fd-title').textContent=r.coIcon+' '+r.title;
  const rows=[['الشركة',r.coIcon+' '+r.coName],['الإدارة',r.dept],['المسمى',r.title],['نوع الطلب',r.reqTypeLabel],['الشواغر',r.count],['الراتب',r.salary||'—'],['موقع العمل',r.location||'—'],['في الميزانية',r.budget],['المؤهل',r.edu],['السبب',r.reason],['الأثر',r.impact],['مقدم الطلب',r.sub]];
  document.getElementById('fd-body').innerHTML=rows.map(([l,val])=>`<div class="dr"><span class="dl">${l}</span><span class="dv">${val||'—'}</span></div>`).join('');
  document.getElementById('fin-name').value='';document.getElementById('fin-notes').value='';
  goTo('fin-det');
}
function finDecide(ok){
  const nm=v('fin-name').trim();if(!nm){notify('يرجى كتابة اسم المعتمد');return}
  loadDB();const r=DB.requests.find(x=>x.id===curId);
  if(r){r.status=ok?'approved':'closed';r.finName=nm;r.finNotes=v('fin-notes');r.finTime=today();r.log.push({t:'قرار المالية: '+(ok?'معتمد':'مرفوض'),s:nm+' — '+today(),c:ok?'green':'red'});saveDB()}
  document.getElementById('fin-ok-ico').textContent=ok?'✅':'❌';
  document.getElementById('fin-ok-ti').textContent=ok?'تم الاعتماد':'تم الرفض';
  document.getElementById('fin-ok-su').textContent=ok?'وصل القرار للموارد البشرية.':'تم إبلاغ الموارد البشرية بالرفض.';
  goTo('fin-ok');
}

// CANDIDATES
function renderCandidates(){
  loadDB();
  const C=DB.candidates||[];
  // fill company dropdown
  const sel=document.getElementById('c-co');
  sel.innerHTML='<option>أي شركة</option>'+COMPANIES.map(c=>`<option>${c.name}</option>`).join('');
  const tbody=document.getElementById('cand-tbody');
  if(!C.length){tbody.innerHTML=`<tr><td colspan="9"><div class="empty">لا يوجد مرشحون بعد</div></td></tr>`;return}
  tbody.innerHTML=[...C].reverse().map(c=>`<tr>
    <td style="font-weight:500">${c.name}</td>
    <td>${c.major||'—'}</td>
    <td>${c.exp||'—'}</td>
    <td>${c.nat||'—'}</td>
    <td>${c.city||'—'}</td>
    <td>${c.target||'—'}</td>
    <td>${c.co||'—'}</td>
    <td><span class="badge ${CAND_STATUS_CLS[c.status]||'b-gray'}">${c.status}</span></td>
    <td>${c.source||'—'}</td>
  </tr>`).join('');
}
function showAddCandidate(){
  const card=document.getElementById('cand-form-card');
  card.style.display=card.style.display==='none'?'block':'none';
}
function saveCandidate(){
  if(!v('c-name')||!v('c-phone')){notify('يرجى إدخال الاسم والجوال');return}
  loadDB();
  if(!DB.candidates)DB.candidates=[];
  DB.candidates.push({name:v('c-name'),phone:v('c-phone'),email:v('c-email'),nat:v('c-nat'),city:v('c-city'),edu:v('c-edu'),major:v('c-major'),exp:v('c-exp'),target:v('c-target'),co:v('c-co'),source:v('c-source'),status:v('c-status'),notes:v('c-notes'),added:today()});
  saveDB();notify('✅ تم حفظ المرشح');
  document.getElementById('cand-form-card').style.display='none';
  ['c-name','c-phone','c-email','c-major','c-target','c-notes'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=''});
  renderCandidates();
}

